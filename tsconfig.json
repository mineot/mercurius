{
  "compilerOptions": {
    "baseUrl": "./",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["esnext", "dom"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["resources/scripts/*"],
      "@api": ["resources/scripts/api.ts"],
      "@component/*": ["resources/scripts/components/*"],
      "@config/*": ["resources/scripts/configuration/*"],
      "@constant/*": ["resources/scripts/constants/*"],
      "@helper/*": ["resources/scripts/helpers/*"],
      "@layout/*": ["resources/scripts/layouts/*"],
      "@model/*": ["resources/scripts/models/*"],
      "@page/*": ["resources/scripts/pages/*"],
      "@store/*": ["resources/scripts/stores/*"],
      "@widget/*": ["resources/scripts/widgets/*"]
    }
  },
  "include": [
    "resources/scripts/**/*.ts",
    "resources/scripts/**/*.d.ts",
    "resources/scripts/**/*.tsx",
    "resources/scripts/**/*.vue"
  ]
}
